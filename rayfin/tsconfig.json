    "compilerOptions": {
        "outDir": ".temp/compiled",
        "rootDir": ".",
        "declaration": true,
        "composite": true,
        "noEmit": false,
        "module": "nodenext",
        "moduleResolution": "nodenext"
    },
    "include": [
        "**/*"
    ],
    "exclude": [
        ".temp/**/*"
    ]
}